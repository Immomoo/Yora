# Default Shelby route used when the app opens.
# Allowed values: testnet, shelbynet
VITE_YORA_NETWORK=testnet

# Aptos API key used by the wallet adapter on Shelby Testnet.
VITE_APTOS_API_KEY=

# Optional Aptos API key override for Shelbynet.
# If empty, the app falls back to VITE_APTOS_API_KEY.
VITE_SHELBYNET_APTOS_API_KEY=

# Optional shared Shelby API key fallback for both networks.
VITE_SHELBY_API_KEY=

# Shelby API key for Shelbynet Devnet writes.
# If empty, the app falls back to VITE_SHELBY_API_KEY.
VITE_SHELBYNET_API_KEY=

# Shelby API key for Shelby Testnet writes.
# If empty, the app falls back to VITE_SHELBY_API_KEY.
VITE_SHELBY_TESTNET_API_KEY=

# Optional production key-release service.
# Leave empty for the development browser key vault.
VITE_YORA_KEY_RELEASE_URL=

# Base64-encoded RSA-OAEP SHA-256 SPKI public key used to encrypt escrowed capsule keys
# before sending them to the remote key-release service.
VITE_YORA_KEY_RELEASE_PUBLIC_KEY=

# Optional Aptos Move registry module address.
# When set, Yora submits a register_capsule transaction after Shelby accepts the blob.
VITE_YORA_REGISTRY_ADDRESS=

# Server-only variables for the key-release API.
# Do not expose these as VITE_ variables.
YORA_KEY_RELEASE_PRIVATE_KEY=
YORA_KV_REST_API_URL=
YORA_KV_REST_API_TOKEN=
